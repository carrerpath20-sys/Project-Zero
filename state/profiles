#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
🧠 PROFILER — Cross-Target Psychological Profiling (Level 5)
- Analyzes JS code style (comments, variable naming, indentation).
- Creates a deterministic profile for each target.
- Matches profiles across targets to predict developer overlap.
- Lightweight: uses deterministic features by default (0 API calls).
- Optional: Uses SBERT for semantic similarity (if installed).
- Auto-creates state/profiles/ directory.
"""

import re
import json
import logging
from pathlib import Path
from typing import Dict, Any, List, Optional, Tuple

logger = logging.getLogger("ZeroRecon")

class Profiler:
    """
    Level 5 Profiler: Lightweight, OPSEC-safe code style analyzer.
    """
    def __init__(self, config: Dict = None, base_dir: Path = Path("state/profiles")):
        self.config = config or {}
        self.base_dir = Path(base_dir)
        # ফোল্ডার তৈরি (যদি না থাকে)
        self.base_dir.mkdir(parents=True, exist_ok=True)
        
        # Optional SBERT (ভারী মডেল, তবে শুধুমাত্র ইনস্টল থাকলেই লোড হবে)
        self.sbert = None
        try:
            from sentence_transformers import SentenceTransformer
            self.sbert = SentenceTransformer('all-MiniLM-L6-v2')
            logger.info("🧠 Profiler: SBERT loaded for semantic matching.")
        except ImportError:
            logger.info("🧠 Profiler: SBERT not installed. Using deterministic matching only.")
        except Exception as e:
            logger.warning(f"⚠️ Profiler: SBERT load failed: {e}")
        
        self._profiles_cache = self._load_all_profiles()
    
    def _load_all_profiles(self) -> Dict[str, Dict]:
        """Load all existing profiles from disk."""
        profiles = {}
        for profile_file in self.base_dir.glob("*.json"):
            try:
                with open(profile_file, 'r') as f:
                    data = json.load(f)
                    target = data.get("profile_id", profile_file.stem)
                    profiles[target] = data
            except:
                pass
        return profiles
    
    def profile_js(self, target: str, js_content: str) -> Dict[str, Any]:
        """
        Extract coding style features and create/update a profile.
        Returns: { "profile_id": target, "features": {...}, "matches": [...] }
        """
        if not js_content or len(js_content) < 50:
            return {
                "profile_id": target,
                "features": {},
                "matches": [],
                "status": "insufficient_data"
            }
        
        # ১. ডিটারমিনিস্টিক ফিচার এক্সট্রাক্ট
        features = self._extract_features(js_content)
        
        # ২. প্রোফাইল তৈরি
        profile = {
            "profile_id": target,
            "target": target,
            "features": features,
            "timestamp": Path(self.base_dir / f"{target}.json").stat().st_mtime if (self.base_dir / f"{target}.json").exists() else None
        }
        
        # ৩. ম্যাচিং (অফলাইন)
        matches = self._find_matches(profile)
        
        # ৪. সেমান্টিক ম্যাচিং (যদি SBERT থাকে)
        semantic_matches = []
        if self.sbert and len(js_content) > 200:
            try:
                # প্রথম ৫০০ অক্ষর নিয়ে এম্বেডিং
                sample = js_content[:500]
                for existing_id, existing_profile in self._profiles_cache.items():
                    if existing_id == target:
                        continue
                    existing_text = existing_profile.get("sample", js_content[:500])
                    # সিমিলারিটি স্কোর
                    emb1 = self.sbert.encode(sample)
                    emb2 = self.sbert.encode(existing_text)
                    from numpy import dot, linalg
                    sim = dot(emb1, emb2) / (linalg.norm(emb1) * linalg.norm(emb2))
                    if sim > 0.7:
                        semantic_matches.append({
                            "profile_id": existing_id,
                            "similarity": float(sim),
                            "type": "semantic"
                        })
            except Exception as e:
                logger.debug(f"Semantic matching failed for {target}: {e}")
        
        # ৫. ম্যাচ একত্রিত
        all_matches = matches + semantic_matches
        all_matches.sort(key=lambda x: x.get("similarity", 0), reverse=True)
        
        # ৬. প্রোফাইল সেভ
        self._save_profile(profile, js_content[:2000])  # স্যাম্পল সেভ
        
        return {
            "profile_id": target,
            "features": features,
            "matches": all_matches[:3],
            "semantic_used": bool(self.sbert),
            "status": "profiled"
        }
    
    def _extract_features(self, js_content: str) -> Dict:
        """Deterministic feature extraction (fast, 0 API calls)."""
        lines = js_content.split('\n')
        total_lines = len(lines)
        if total_lines == 0:
            return {}
        
        # কমেন্ট রেশিও
        comment_lines = sum(1 for l in lines if l.strip().startswith(('//', '/*', '*')))
        comment_ratio = comment_lines / max(1, total_lines)
        
        # ইন্ডেন্টেশন
        spaces = sum(1 for l in lines if l.startswith('  '))
        tabs = sum(1 for l in lines if l.startswith('\t'))
        if spaces > tabs * 2:
            indentation = "spaces"
        elif tabs > spaces * 2:
            indentation = "tabs"
        else:
            indentation = "mixed"
        
        # ভ্যারিয়েবল স্টাইল
        camel = re.search(r'[a-z]+[A-Z]', js_content)
        snake = re.search(r'[a-z]+_[a-z]', js_content)
        if camel and not snake:
            var_style = "camelCase"
        elif snake and not camel:
            var_style = "snake_case"
        elif camel and snake:
            var_style = "mixed"
        else:
            var_style = "unknown"
        
        # গড় লাইন দৈর্ঘ্য
        avg_len = sum(len(l) for l in lines) / max(1, total_lines)
        
        # ফাংশন ডিক্লারেশন স্টাইল
        func_style = "function" if "function " in js_content else "arrow" if "=>" in js_content else "unknown"
        
        return {
            "comment_ratio": round(comment_ratio, 2),
            "indentation": indentation,
            "variable_style": var_style,
            "avg_line_length": round(avg_len, 2),
            "function_style": func_style,
            "line_count": total_lines
        }
    
    def _find_matches(self, profile: Dict) -> List[Dict]:
        """Find deterministic matches with existing profiles."""
        matches = []
        features = profile.get("features", {})
        if not features:
            return matches
        
        for existing_id, existing_profile in self._profiles_cache.items():
            if existing_id == profile["profile_id"]:
                continue
            existing_features = existing_profile.get("features", {})
            if not existing_features:
                continue
            
            score = 0
            # কমেন্ট রেশিও (যদি কাছাকাছি)
            if abs(features.get("comment_ratio", 0) - existing_features.get("comment_ratio", 0)) < 0.1:
                score += 0.2
            # ইন্ডেন্টেশন
            if features.get("indentation") == existing_features.get("indentation"):
                score += 0.3
            # ভ্যারিয়েবল স্টাইল
            if features.get("variable_style") == existing_features.get("variable_style"):
                score += 0.3
            # ফাংশন স্টাইল
            if features.get("function_style") == existing_features.get("function_style"):
                score += 0.2
            
            if score > 0.5:
                matches.append({
                    "profile_id": existing_id,
                    "similarity": score,
                    "type": "deterministic"
                })
        
        return matches
    
    def _save_profile(self, profile: Dict, sample: str = ""):
        """Save profile to disk, including a small sample for semantic matching."""
        profile_path = self.base_dir / f"{profile['profile_id']}.json"
        # Update profile with sample (for SBERT)
        if sample:
            profile["sample"] = sample[:2000]
        
        try:
            with open(profile_path, 'w') as f:
                json.dump(profile, f, indent=2)
            # Update cache
            self._profiles_cache[profile["profile_id"]] = profile
        except Exception as e:
            logger.error(f"❌ Profile save failed for {profile['profile_id']}: {e}")
    
    def get_profile(self, target: str) -> Optional[Dict]:
        """Retrieve a specific profile."""
        return self._profiles_cache.get(target)
    
    def get_all_profiles(self) -> Dict:
        """Return all cached profiles."""
        return self._profiles_cache
    
    def clear(self):
        """Delete all profiles."""
        for f in self.base_dir.glob("*.json"):
            f.unlink()
        self._profiles_cache = {}
        logger.info("🗑️ All profiles cleared.")
